import { TapTracker } from "types.slint";

export component ThumbnailCell {
    in property <int> item-id;
    in property <image> thumb-image;
    in property <bool> thumb-ready;
    in property <string> media-type;
    in property <length> size: 256px;
    callback tapped(int, string);

    width: size;
    height: size;

    Rectangle {
        background: #222222;
        border-radius: 2px;

        if thumb-ready: Image {
            source: thumb-image;
            width: size;
            height: size;
            image-fit: cover;
        }

        if !thumb-ready: Rectangle {
            background: #2a2a2a;
            // Placeholder shimmer
        }

        // Video indicator overlay
        if media-type == "video": Rectangle {
            x: size - 28px;
            y: size - 28px;
            width: 24px;
            height: 24px;
            background: #00000088;
            border-radius: 12px;
            Text {
                text: "▶";
                color: white;
                font-size: 10px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        TouchArea {
            pointer-event(e) => {
                if e.kind == PointerEventKind.down {
                    TapTracker.armed-id = item-id;
                } else if e.kind == PointerEventKind.up {
                    if TapTracker.armed-id == item-id {
                        tapped(item-id, media-type);
                    }
                    TapTracker.armed-id = -1;
                } else if e.kind == PointerEventKind.cancel {
                    TapTracker.armed-id = -1;
                }
            }
        }
    }
}
